# ── App ─────────────────────────────────────────────────────────────────
APP_ENV=development

# ── Database (Neon PostgreSQL) ──────────────────────────────────────────
# Connection string format: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/lexad?sslmode=require

# ── Security ────────────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production
COMPETITION_MODE=false
LOGIN_RATE_LIMIT_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=600
AI_RATE_LIMIT_REQUESTS=10
AI_RATE_LIMIT_WINDOW_SECONDS=600

# Production demo seed (Render only; use 12+ character passwords)
DEMO_SEED_ENABLED=false
DEMO_ADMIN_PASSWORD=
DEMO_MARKETING_PASSWORD=
DEMO_LEGAL_PASSWORD=

# ── Frontend ────────────────────────────────────────────────────────────
FRONTEND_ORIGIN=http://localhost:5173

# ── DeepSeek / AI ──────────────────────────────────────────────────────
# 推荐由管理员登录后在“系统管理 → AI 配置”中填写。环境变量仅用于兼容旧部署。
DEEPSEEK_API_KEY=
