# ── App ─────────────────────────────────────────────────────────────────
APP_ENV=development

# ── Database Mode ───────────────────────────────────────────────────────
# local = 本地 SQLite（默认，双击启动使用此模式）
# neon  = Neon PostgreSQL（需要手动执行迁移，不会由一键启动自动迁移）
DATABASE_MODE=local
LOCAL_DATABASE_URL=sqlite:///./lexad.db

# 仅 DATABASE_MODE=neon 时读取以下配置
# DATABASE_URL 格式: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/dbname?sslmode=require

# 注意：
# - 本地默认不连接 Neon
# - 不要提交真实连接串
# - 生产环境必须使用 neon
# - SQLite 和 Neon 不自动同步

# ── Security ────────────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production
COMPETITION_MODE=false
LOGIN_RATE_LIMIT_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=600
AI_RATE_LIMIT_REQUESTS=10
AI_RATE_LIMIT_WINDOW_SECONDS=600

# Production demo seed (Render only; use 12+ character passwords)
DEMO_SEED_ENABLED=false
DEMO_ADMIN_PASSWORD=
DEMO_MARKETING_PASSWORD=
DEMO_LEGAL_PASSWORD=

# ── Frontend ────────────────────────────────────────────────────────────
FRONTEND_ORIGIN=http://localhost:5173

# ── DeepSeek / AI ──────────────────────────────────────────────────────
# 推荐由管理员登录后在“系统管理 → AI 配置”中填写。环境变量仅用于兼容旧部署。
DEEPSEEK_API_KEY=
